Program Summary:
This program controls an autonomous rover that follows a line
using IR sensors, detects and tracks objects using a Pixy2
camera, and grabs the detected object using a claw and lift
servo mechanism.

The robot operates in three modes:
1. Line Following – Uses front and rear IR sensors to follow
   a line on the ground.
2. Pixy Tracking – Uses proportional control with the Pixy2
   camera to center on and approach an object.
3. Object Grabbing – Activates the claw and lift servos to
   grab the object once the robot is close enough.
------------------------------------------------------------
*/

#include <CytronMotorDriver.h>
#include <Pixy2.h>
#include <Servo.h>

// Camera object for object detection/tracking
Pixy2 pixy;

// Servo objects for the claw and lift mechanism
Servo claw;
Servo lift;

// IR line sensor pins
int flsensor = 4;
int frsensor = 5;
int blsensor = 8;
int brsensor = A1;

// Robot mode:
// 1 = line follow
// 2 = Pixy tracking
// 3 = grab object
int function = 1;

// Stores detected object width
int object_width = 40;

// Pixy tracking control values
float Kp = 1.5;
int center_x = 160;
int turn_threshold = 15;
int min_speed = 50;
int max_speed = 200;
int target_width = 150;

// Motor driver objects
CytronMD motorLeft(PWM_DIR, 6, 7);
CytronMD motorRight(PWM_DIR, 3, 2);

// Speed limits for motor protection/control
const int MAX_SPEED = 250;
const int MIN_SPEED = 50;

// Keeps motor speed within allowed range
int clampSpeed(int s) {
  if (s > MAX_SPEED) {
    return MAX_SPEED;
  }
  else if (s < MIN_SPEED) {
    return 50;
  } 
  else {
    return s;
  }
}

// -------------------- Movement Functions --------------------

// Sets left and right motor speeds directly
void setMotors(int leftSpeed, int rightSpeed) {
  motorLeft.setSpeed(leftSpeed);
  motorRight.setSpeed(rightSpeed);
}

// Stops both motors
void stopMotors() {
  setMotors(0, 0);
}

// Drives forward
void forward(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, limspeed);
}

// Turns left in place
void turnLeft(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, -limspeed);
}

// Turns right in place
void turnRight(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(-limspeed, limspeed);
}

// -------------------- Pixy Camera Tracking --------------------

// Tracks the detected object and moves toward it
void pixytrack() {
  pixy.ccc.getBlocks();
  
  if (pixy.ccc.numBlocks > 0) {

    int object_x = pixy.ccc.blocks[0].m_x;
    int object_width = pixy.ccc.blocks[0].m_width;

    // Calculate horizontal error from center of camera view
    int error = object_x - center_x;

    // Proportional turning speed based on error
    int turnspeed = abs(error) * Kp;
    int turnconstrained = (turnspeed, min_speed, max_speed);

    // Object is left of center
    if (error < -turn_threshold) {
      turnRight(turnconstrained);

      // Stop and switch to grab mode if close enough
      if (object_width > target_width) {
        stopMotors();
        function = 3;
        return;
      }
    } 

    // Object is right of center
    else if (error > turn_threshold) {
      turnLeft(turnconstrained);

      // Stop and switch to grab mode if close enough
      if (object_width > target_width) {
        stopMotors();
        function = 3;
        return;
      }
    } 

    // Object is centered
    else {
      if (object_width < target_width) {
        forward(250);
      } 
      else {
        stopMotors();
        function = 3;
        return;
      }
    }
  } 
  
  // No object detected, keep searching
  else {
    turnRight(150);
  }
}

// -------------------- Claw Function --------------------

// 45 is base for lift
// 90 is base for claw
void grabObject() {
  claw.write(25);
  lift.write(20);
  return;
}

// -------------------- IR Sensor Line Following --------------------

// Uses IR sensors to follow line and switch to Pixy mode when needed
void irsensor() {
  
  int frontleft = digitalRead(flsensor);
  int frontright = digitalRead(frsensor);
  int backleft = digitalRead(blsensor);
  int backright = digitalRead(brsensor);
  
  // Both front sensors detect the trigger condition
  if (frontleft == 1 && frontright == 1) {
    stopMotors();
    function = 2;
    return; 
  }

  // Adjust left
  else if (frontright == 0 && frontleft == 1) {
    turnLeft(118);
  }

  // Adjust right
  else if (frontright == 1 && frontleft == 0) {
    turnRight(118);
  }

  // Hard right correction
  else if (frontright == 0 && frontleft == 0 && backright == 1 && backleft == 0) {
    turnRight(152);
  }

  // Hard left correction
  else if (frontright == 0 && frontleft == 0 && backright == 0 && backleft == 1) {
    turnLeft(152);
  }

  // Default forward movement
  else {
    forward(135);
  }
}

// -------------------- Setup --------------------

void setup() {
  pixy.init();

  claw.attach(9);
  lift.attach(10);

  // Set servos to starting positions
  claw.write(90);
  lift.write(45);

  // Set sensor pin modes
  pinMode(flsensor, INPUT);
  pinMode(frsensor, INPUT);
  pinMode(blsensor, INPUT);
  pinMode(brsensor, INPUT_PULLUP);
}

// -------------------- Main Loop --------------------

void loop() {
  if (function == 1) {
    irsensor();
  }
  else if (function == 2) {
    pixytrack();
  }
  else {
    grabObject();
  }
}
