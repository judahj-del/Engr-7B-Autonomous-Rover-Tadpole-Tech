#include <CytronMotorDriver.h>
#include <Pixy2.h>
#include <Servo.h>

Pixy2 pixy;

Servo claw;
Servo lift;

int flsensor = 4;
int frsensor = 5;
int blsensor = 8;
int brsensor = A1;
int function = 1;
int object_width = 40;

//pixy variables
float Kp = 1.5;
int center_x = 160;
int turn_threshold = 20;
int min_speed = 50;
int max_speed = 200;
int target_width = 150;

// motors (ONLY DEFINE ONCE)
CytronMD motorLeft(PWM_DIR, 6, 7);
CytronMD motorRight(PWM_DIR, 3, 2);

const int MAX_SPEED = 200;
const int MIN_SPEED = 50;
// keeps speed in safe range

int clampSpeed(int s) {
  if (s > MAX_SPEED) {
    return MAX_SPEED;
  }
  else if (s < MIN_SPEED) {
    return 50;
  } 
  else {
  return s;
  }
}

void setMotors(int leftSpeed, int rightSpeed) {
  motorLeft.setSpeed(leftSpeed);
  motorRight.setSpeed(rightSpeed);
}

void stopMotors() {
  setMotors(0, 0);
}

void forward(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, limspeed); //left forward right forward
}

void turnLeft(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, -limspeed); //left backward right forward
}

void turnRight(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(-limspeed, limspeed); //left forward right backward
}
void hardRight(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(-limspeed, limspeed); //left forward right backward
}

void hardLeft(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, -limspeed); //left backward right forward
}

void pixytrack(){
  pixy.ccc.getBlocks();
  
  if(pixy.ccc.numBlocks > 0) {

    int object_x = pixy.ccc.blocks[0].m_x;
    int object_width = pixy.ccc.blocks[0].m_width;
    Serial.print(object_width);
    Serial.println(object_x);
    int error = object_x - center_x;
    int turnspeed = abs(error) * Kp;
    int turnconstrained = (turnspeed, min_speed, max_speed); //calculate error and use it to find the speed for proportional control

    if(error < -turn_threshold){ // if error is negative & less than turn threshold, that means the object is to the left of the rover
      turnRight(turnconstrained); 
      if (object_width > target_width){
        stopMotors();
        Serial.print("Bye");
        function = 3;
        return;
      }
    } 
      else if(error > turn_threshold) { // if the error is positive and greater than the threshold, then the object is to the right of the rover.
        turnLeft(turnconstrained);
        if (object_width > target_width){
          stopMotors();
          Serial.print("Hi");
          function = 3;
          return;
        }
    } 
    else {
          if(object_width < target_width){
              forward(200);
          } else {
              stopMotors();
              Serial.print("Good");
              function = 3;
              return;
          }
    }
  } 
  else {
        turnRight(150);
  }

}

