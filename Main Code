const int MAX_SPEED = 200;
const int MIN_SPEED = 50;
// keeps speed in safe range

int clampSpeed(int s) {
  if (s > MAX_SPEED) {
    return MAX_SPEED;
  }
  else if (s < MIN_SPEED) {
    return 50;
  } 
  else {
  return s;
  }
}

void setMotors(int leftSpeed, int rightSpeed) {
  motorLeft.setSpeed(leftSpeed);
  motorRight.setSpeed(rightSpeed);
}

void stopMotors() {
  setMotors(0, 0);
}

void forward(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, limspeed); //left forward right forward
}

void turnLeft(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(limspeed, 0); //left backward right forward
}

void turnRight(int speed) {
  int limspeed = clampSpeed(speed);
  setMotors(0, limspeed); //left forward right backward
}

