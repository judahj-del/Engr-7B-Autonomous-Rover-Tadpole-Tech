}

void setup() {

  Serial.begin(115200);
  Serial.begin(9600);
  
  pixy.init();

  claw.attach(9);
  lift.attach(10);
  claw.write(90);
  lift.write(45);
  pinMode(flsensor, INPUT);
  pinMode(frsensor, INPUT);
  pinMode(blsensor, INPUT);
  pinMode(brsensor, INPUT_PULLUP);
}
void loop() {
  if (function == 1){
  irsensor();
  }
  else if (function ==2){
  pixytrack();
  }
  else
  grabObject();

 
}
